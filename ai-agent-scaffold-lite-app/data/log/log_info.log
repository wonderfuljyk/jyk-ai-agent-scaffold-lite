turns without sorting.\n     * - An empty array is handled implicitly and remains unchanged.\n     *\n     * @param arr the array to be sorted. May be null or empty.\n     */\n    public static void bubbleSort(int[] arr) {\n        if (arr == null) {\n            // Null check to prevent NullPointerException\n            return;\n        }\n        int n = arr.length;\n        boolean swapped;\n        for (int i = 0; i < n - 1; i++) {\n            swapped = false;\n            for (int j = 0; j < n - 1 - i; j++) {\n                if (arr[j] > arr[j + 1]) {\n                    // Swap adjacent elements\n                    int temp = arr[j];\n                    arr[j] = arr[j + 1];\n                    arr[j + 1] = temp;\n                    swapped = true;\n                }\n            }\n            // If no swaps occurred, array is already sorted\n            if (!swapped) {\n                break;\n            }\n        }\n    }\n\n    /**\n     * Prints the contents of an integer array to System.out, space-separated.\n     *\n     * @param arr the array to be printed. May be null or empty.\n     */\n    public static void printArray(int[] arr) {\n        if (arr == null) {\n            System.out.println(\"null\");\n            return;\n        }\n        for (int num : arr) {\n            System.out.print(num + \" \");\n        }\n        System.out.println();\n    }\n\n    public static void main(String[] args) {\n        int[] array = {5, 3, 8, 4, 2};\n        bubbleSort(array);\n        printArray(array);\n    }\n}\n```"]
